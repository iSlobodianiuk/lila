# Скопіюй цей файл як ".env" у корені lila (та заповни значення).
# PowerShell: Copy-Item env.example .env

# PostgreSQL — реальні дані (Neon, Supabase, локальна БД)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (листи після фіналу; опційно)
RESEND_API_KEY=""
EMAIL_FROM="Lila <onboarding@resend.dev>"

# OpenAI
OPENAI_API_KEY=""
