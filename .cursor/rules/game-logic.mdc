## СТАН ГРИ — ПОВНА СХЕМА

```typescript
// src/types/game.ts

export type GamePhase = 
  | 'request_forming'  // гравець формулює запит і кидає для входу
  | 'playing'          // гравець грає
  | 'finished';        // гравець дійшов до 68

export interface GameState {
  phase: GamePhase;
  
  // Запит
  playerRequest: string;        // поточний текст запиту
  fixedRequest: string | null;  // зафіксований запит (після 6)
  entryRollCount: number;       // скільки разів кидав для входу
  
  // Позиція
  currentPosition: number;      // поточна клітинка (0 = ще не увійшов)
  previousPosition: number;     // попередня клітинка
  
  // Кидки
  lastRolls: number[];          // останній набір кидків [6, 3]
  totalMoves: number;           // загальна кількість ходів після входу
  
  // Монетизація
  movesAfterEntry: number;      // ходів після входу в гру
  isPaid: boolean;              // чи оплатив гру
  
  // Історія
  visitedCells: {
    cellNumber: number;
    cellName: string;
    timestamp: Date;
    rolls: number[];
    wasSnake: boolean;
    wasArrow: boolean;
  }[];
  
  // Чат
  chatMessages: {
    role: 'user' | 'assistant';
    content: string;
    cellNumber?: number;
    timestamp: Date;
  }[];
}
