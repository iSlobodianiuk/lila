## РЕАЛІЗАЦІЯ АНІМАЦІЇ ХОДУ

При кожному ході показувати послідовну анімацію:

```typescript
// src/hooks/useGameAnimation.ts

export async function animateMove(
  positions: number[],
  setCurrentPosition: (pos: number) => void,
  onSnake: (from: number, to: number) => void,
  onArrow: (from: number, to: number) => void,
) {
  for (const pos of positions) {
    setCurrentPosition(pos);
    
    // Перевірка змії
    if (SNAKES[pos]) {
      await delay(800);
      // Показати анімацію змії
      onSnake(pos, SNAKES[pos]);
      setCurrentPosition(SNAKES[pos]);
      await delay(1000);
    }
    
    // Перевірка стріли
    if (ARROWS[pos]) {
      await delay(800);
      // Показати анімацію стріли
      onArrow(pos, ARROWS[pos]);
      setCurrentPosition(ARROWS[pos]);
      await delay(1000);
    }
    
    await delay(500); // пауза між кроками
  }
}

function delay(ms: number): Promise<void> {
  return new Promise(resolve => setTimeout(resolve, ms));
}
```

